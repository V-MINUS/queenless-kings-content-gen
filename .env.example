# ─────────────────────────────────────────────────────────────────
# QK Content Generator — environment variables
# ─────────────────────────────────────────────────────────────────
# Local: copy to `.env.local`
# Production (Vercel): paste into Project → Settings → Environment Variables
#
# Add MULTIPLE keys per provider as comma-separated values to maximize
# free-tier throughput via round-robin rotation.
# Even ONE provider works.
# ─────────────────────────────────────────────────────────────────

# ── Optional shared password (recommended for public deployment)
# Send via header: x-app-password: <your-password>
APP_PASSWORD=

# ─── No-signup free providers ───────────────────────────────────

# Pollinations.ai (anonymous, completely free, no signup needed)
# Set any string as the "key" — the provider treats it as a referrer token.
POLLINATIONS_API_KEYS=free
POLLINATIONS_MODEL=openai

# ─── Generous free tiers (recommended) ──────────────────────────

# Groq — 30 req/min, very fast llama-3.3
# https://console.groq.com/keys
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras — 1M tokens/day, fastest inference available
# https://cloud.cerebras.ai/
CEREBRAS_API_KEYS=
CEREBRAS_MODEL=llama3.1-70b

# Google Gemini — 1500 req/day on flash
# https://aistudio.google.com/apikey
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter — aggregator with free models
# https://openrouter.ai/keys
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# SambaNova — fast, free tier
# https://cloud.sambanova.ai/
SAMBANOVA_API_KEYS=
SAMBANOVA_MODEL=Meta-Llama-3.1-70B-Instruct

# GitHub Models — free with personal access token
# https://github.com/marketplace/models  +  https://github.com/settings/tokens
GITHUB_MODELS_TOKENS=
GITHUB_MODELS_MODEL=gpt-4o-mini

# NVIDIA NIM — 1000 free credits, generous monthly limits
# https://build.nvidia.com/
NVIDIA_API_KEYS=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# HuggingFace Inference — free with HF token, rate-limited
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEYS=
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Mistral La Plateforme — free experimental tier
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEYS=
MISTRAL_MODEL=mistral-small-latest

# Cohere — 1000 req/month trial
# https://dashboard.cohere.com/api-keys
COHERE_API_KEYS=
COHERE_MODEL=command-r-08-2024

# ─── Free trial credits (sign up bonuses) ───────────────────────

# Together AI — $1 credit + free models
# https://api.together.ai/
TOGETHER_API_KEYS=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# Hyperbolic — $10 free credit on signup
# https://app.hyperbolic.xyz/
HYPERBOLIC_API_KEYS=
HYPERBOLIC_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# DeepSeek — small signup credit, very cheap paid
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEYS=
DEEPSEEK_MODEL=deepseek-chat

# xAI Grok — $25/month free if you opt into data sharing
# https://console.x.ai/
XAI_API_KEYS=
XAI_MODEL=grok-beta

# ─── Paid only ──────────────────────────────────────────────────

OPENAI_API_KEYS=
OPENAI_MODEL=gpt-4o-mini
